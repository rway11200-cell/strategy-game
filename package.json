{
  "name": "pixi-project",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite preview --host 0.0.0.0 --port ${PORT:-4173}",
    "build": "tsc && vite build",
    "lint": "eslint .",
    "dev": "vite",
    "clear-assets": "rm -rf .assetpack public/assets",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest --reporter=verbose",
    "test:visual": "playwright test --reporter=list",
    "test:visual:update": "playwright test --reporter=list --update-snapshots",
    "preview": "vite preview"
  },
  "dependencies": {
    "@esotericsoftware/spine-pixi-v8": "^4.2.74",
    "@pixi/devtools": "^2.0.1",
    "@pixi/sound": "^6.0.1",
    "@pixi/ui": "^2.2.2",
    "@rollup/rollup-linux-arm64-gnu": "^4.62.2",
    "motion": "^12.4.7",
    "pixi.js": "^8.8.1"
  },
  "devDependencies": {
    "@assetpack/core": "^1.4.0",
    "@eslint/js": "^9.38.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.9.1",
    "@vitest/ui": "3.2.4",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.2.6",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.46.1",
    "vite": "^6.2.0",
    "vitest": "^3.2.4"
  }
}
